---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You | Harris Heritage Cavaliers"
  description="Thank you for contacting Harris Heritage Cavaliers. We will respond to your inquiry shortly."
>
  <section class="thank-you-section">
    <div class="thank-you-container">
      <div class="success-icon">
        <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
      </div>
      <h1>Thank You!</h1>
      <p class="main-text">Your message has been received. We appreciate your interest in Harris Heritage Cavaliers and will get back to you within 24 hours.</p>
      <p class="sub-text">In the meantime, feel free to browse our available puppies or learn more about our breeding program.</p>
      <div class="actions">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/faq" class="btn-secondary">View FAQ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thank-you-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 4rem 1.5rem;
    background: #F8F5F0;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
  }

  .thank-you-container {
    text-align: center;
    max-width: 600px;
  }

  .success-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #2C3E6B, #C4A882);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
  }

  .success-icon svg {
    width: 40px;
    height: 40px;
    fill: white;
  }

  h1 {
    font-size: 2.5rem;
    color: #2C3E6B;
    margin: 0 0 1rem;
  }

  .main-text {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .sub-text {
    font-size: 1rem;
    color: #888;
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: linear-gradient(135deg, #2C3E6B, #C4A882);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(44, 62, 107, 0.3);
    color: white;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    background: white;
    color: #2C3E6B;
    padding: 0.875rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid #2C3E6B;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: #2C3E6B;
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2rem;
    }

    .actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
