---
// FeaturedPuppies component - PetZo style puppy grid
import { puppies } from '../data/puppies';
---

<section class="featured-section">
  <div class="section-header">
    <span class="section-badge">Our Puppies</span>
    <h2 class="section-title">
      Meet Our Cavalier
      <span class="highlight">Puppies</span>
    </h2>
    <p class="section-subtitle">Adorable Cavalier King Charles Spaniel puppies looking for their forever homes</p>
  </div>

  <div class="puppies-container">
    <div class="puppies-grid">
      {puppies.map((puppy) => (
        <article class="puppy-card">
          <div class="card-image">
            <span class="status-badge">{puppy.status}</span>
            <img src={puppy.image} alt={puppy.name} loading="lazy">
          </div>
          <div class="card-content">
            <h3 class="puppy-name">{puppy.name}</h3>
            <div class="card-meta">
              <span class="meta-item">{puppy.sex}</span>
              <span class="meta-divider">|</span>
              <span class="meta-item">{puppy.age}</span>
            </div>
            <div class="card-price">${puppy.price}</div>
            <a href="/available-puppies" class="btn-view">View Details</a>
          </div>
        </article>
      ))}
    </div>
    <div class="view-all-wrapper">
      <a href="/available-puppies" class="btn-view-all">
        View All Puppies
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .featured-section {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: #F9F9F6;
    padding: 5rem 1.5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-badge {
    display: inline-block;
    background: #F5C518;
    color: #1A1A1A;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: #1A1A1A;
    margin: 0 0 0.75rem;
  }

  .highlight {
    position: relative;
    display: inline-block;
  }

  .highlight::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 8px;
    background: #F5C518;
    opacity: 0.4;
    z-index: -1;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: #666;
    margin: 0;
  }

  .puppies-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .puppy-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 15px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 2px solid transparent;
  }

  .puppy-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    border-color: #F5C518;
  }

  .card-image {
    position: relative;
    height: 260px;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: transform 0.4s ease;
  }

  .puppy-card:hover .card-image img {
    transform: scale(1.05);
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #F5C518;
    color: #1A1A1A;
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 1;
  }

  .card-content {
    padding: 1.25rem;
  }

  .puppy-name {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    font-size: 0.85rem;
    color: #666;
  }

  .meta-divider {
    color: #ddd;
  }

  .card-price {
    font-size: 1.35rem;
    font-weight: 800;
    color: #1A1A1A;
    margin-bottom: 1rem;
  }

  .btn-view {
    display: block;
    width: 100%;
    background: #1A1A1A;
    color: white;
    padding: 0.7rem;
    border: none;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-view:hover {
    background: #F5C518;
    color: #1A1A1A;
  }

  .view-all-wrapper {
    text-align: center;
    margin-top: 2.5rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #F5C518;
    color: #1A1A1A;
    padding: 0.9rem 2.5rem;
    border-radius: 50px;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(245, 197, 24, 0.3);
  }

  .btn-view-all svg {
    width: 18px;
    height: 18px;
  }

  .btn-view-all:hover {
    background: #D4A800;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 197, 24, 0.4);
    color: #1A1A1A;
  }

  @media (max-width: 900px) {
    .puppies-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .featured-section {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .puppies-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }

    .card-image {
      height: 240px;
    }
  }
</style>
