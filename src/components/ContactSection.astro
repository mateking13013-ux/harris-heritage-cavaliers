---
// ContactSection component - PetZo style
---

<section class="contact-section" id="contact">
  <div class="contact-container">
    <div class="section-header">
      <span class="section-badge">Contact</span>
      <h2 class="section-title">Ready to Adopt a <span class="highlight">Puppy</span>?</h2>
      <p class="section-subtitle">Have questions about our Cavalier King Charles Spaniel puppies or ready to bring one home? We would love to hear from you!</p>
    </div>

    <div class="contact-grid">
      <div class="contact-form-wrapper">
        <h3 class="form-title">Inquiry Form</h3>
        <form class="contact-form" id="homeContactForm">
          <input type="hidden" name="access_key" value="72250639-6e41-40b9-a622-4db67b0a16ff">
          <input type="hidden" name="subject" value="New Inquiry - Harris Heritage Cavaliers">
          <input type="hidden" name="from_name" value="Harris Heritage Cavaliers">

          <div class="form-row">
            <div class="form-group">
              <label for="homeFirstName">First Name *</label>
              <input type="text" id="homeFirstName" name="firstName" required>
            </div>
            <div class="form-group">
              <label for="homeLastName">Last Name *</label>
              <input type="text" id="homeLastName" name="lastName" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="homeEmail">Email Address *</label>
              <input type="email" id="homeEmail" name="email" required>
            </div>
            <div class="form-group">
              <label for="homePhone">Phone *</label>
              <input type="tel" id="homePhone" name="phone" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="homeCity">City</label>
              <input type="text" id="homeCity" name="city" placeholder="e.g. Nashville, TN">
            </div>
            <div class="form-group">
              <label for="homeHowHeard">How Did You Hear About Us?</label>
              <select id="homeHowHeard" name="howHeard">
                <option value="">Select...</option>
                <option value="Google Search">Google Search</option>
                <option value="Social Media">Social Media</option>
                <option value="Referral">Referral from a Friend</option>
                <option value="AKC Marketplace">AKC Marketplace</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="homeMessage">Message</label>
            <textarea id="homeMessage" name="message" placeholder="Tell us about yourself and why you would like to adopt a Cavalier King Charles Spaniel puppy..."></textarea>
          </div>

          <button type="submit" class="btn-submit">
            Send Inquiry
            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </form>
      </div>

      <div class="contact-info">
        <h3 class="info-title">Contact Information</h3>

        <div class="info-item">
          <div class="info-icon">
            <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <div class="info-content">
            <h4>Email</h4>
            <p><a href="mailto:harrisheritagecavaliers@gmail.com">harrisheritagecavaliers@gmail.com</a></p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon">
            <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
          </div>
          <div class="info-content">
            <h4>Response Time</h4>
            <p>We typically respond within<br>24 hours</p>
          </div>
        </div>

        <div class="info-item">
          <div class="info-icon">
            <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <div class="info-content">
            <h4>Location</h4>
            <p>United States</p>
          </div>
        </div>

        <div class="info-note">
          <h4>Our Location</h4>
          <p>We are a family breeder. For the safety and privacy of our family and our puppies, we do not publish our address. Once you contact us, we will happily share our location and arrange a convenient visit or delivery.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('homeContactForm') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const emailInput = form.querySelector('#homeEmail') as HTMLInputElement;

    formData.append("replyto", emailInput.value);

    const originalHTML = submitBtn.innerHTML;
    submitBtn.innerHTML = "Sending...";
    submitBtn.disabled = true;

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData
      });

      const data = await response.json();

      if (response.ok) {
        window.location.href = "/thank-you";
      } else {
        alert("Error: " + data.message);
      }
    } catch (error) {
      alert("Something went wrong. Please try again.");
    } finally {
      submitBtn.innerHTML = originalHTML;
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .contact-section { display: block; font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif); background: #FFFFFF; padding: 5rem 1.5rem; }
  .contact-container { max-width: 1200px; margin: 0 auto; }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-badge { display: inline-block; background: #F5C518; color: #1A1A1A; padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.85rem; font-weight: 700; margin-bottom: 1rem; }
  .section-title { font-size: 2.25rem; font-weight: 700; color: #1A1A1A; margin: 0 0 0.75rem; }
  .highlight { position: relative; }
  .highlight::after { content: ''; position: absolute; bottom: 2px; left: 0; width: 100%; height: 6px; background: #F5C518; opacity: 0.4; z-index: -1; }
  .section-subtitle { font-size: 1.05rem; color: #666; margin: 0 auto; max-width: 550px; line-height: 1.6; }
  .contact-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2rem; align-items: start; }
  .contact-info { background: #F9F9F6; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05); }
  .info-title { font-size: 1.35rem; font-weight: 700; color: #1A1A1A; margin: 0 0 1.5rem; }
  .info-item { display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem; }
  .info-icon { width: 45px; height: 45px; background: #F5C518; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .info-icon svg { width: 22px; height: 22px; fill: #1A1A1A; }
  .info-content h4 { font-size: 1rem; font-weight: 600; color: #1A1A1A; margin: 0 0 0.25rem; }
  .info-content p { font-size: 0.9rem; color: #666; margin: 0; line-height: 1.5; }
  .info-content a { color: #1A1A1A; text-decoration: none; font-weight: 500; }
  .info-content a:hover { color: #F5C518; }
  .info-note { background: rgba(245, 197, 24, 0.1); border-radius: 12px; padding: 1.25rem; margin-top: 1rem; border-left: 3px solid #F5C518; }
  .info-note h4 { font-size: 1rem; font-weight: 600; color: #1A1A1A; margin: 0 0 0.5rem; }
  .info-note p { font-size: 0.9rem; color: #666; margin: 0; line-height: 1.6; }
  .contact-form-wrapper { background: #F9F9F6; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05); }
  .form-title { font-size: 1.35rem; font-weight: 700; color: #1A1A1A; margin: 0 0 1.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-group label { font-size: 0.9rem; font-weight: 600; color: #333; }
  .form-group input, .form-group select, .form-group textarea { padding: 0.875rem 1rem; border: 2px solid #eee; border-radius: 10px; font-size: 0.95rem; font-family: inherit; transition: all 0.3s ease; background: #fff; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: #F5C518; background: white; box-shadow: 0 0 0 3px rgba(245, 197, 24, 0.15); }
  .form-group textarea { min-height: 120px; resize: vertical; }
  .btn-submit { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; background: #F5C518; color: #1A1A1A; padding: 1rem 2rem; border: none; border-radius: 50px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.3s ease; margin-top: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px; }
  .btn-submit:hover { background: #D4A800; transform: translateY(-2px); }
  .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; }
  .btn-submit svg { width: 18px; height: 18px; fill: currentColor; }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .contact-section { padding: 3rem 1rem; } .section-title { font-size: 1.75rem; } .form-row { grid-template-columns: 1fr; } .contact-info, .contact-form-wrapper { padding: 1.5rem; } }
</style>
