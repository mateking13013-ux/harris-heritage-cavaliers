---
// HeroSection component - PetZo style hero with left text, right image, services strip
---

<section class="hero">
  <div class="hero-main">
    <div class="hero-container">
      <div class="hero-content">
        <h1 class="hero-title">
          Find Your Perfect Cavalier
          <span class="highlight-word">
            Companion.
            <svg class="underline-svg" viewBox="0 0 200 12" preserveAspectRatio="none">
              <path d="M2 8 Q50 2 100 7 Q150 12 198 4" stroke="#F5C518" stroke-width="4" fill="none" stroke-linecap="round"/>
            </svg>
          </span>
        </h1>
        <p class="hero-description">Premium Cavalier King Charles Spaniel puppies raised with love, health guaranteed, and ready for their forever home.</p>
        <div class="hero-actions">
          <a href="/available-puppies" class="btn-get-started">GET STARTED</a>
          <a href="/about" class="btn-how-it-works">
            HOW IT WORKS
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
          </a>
        </div>
        <div class="slide-counter">01 / 03</div>
      </div>

      <div class="hero-image-wrapper">
        <div class="dot-pattern dot-pattern-top"></div>
        <div class="hero-image">
          <img src="/images/puppies/leo.jpg" alt="Cavalier King Charles Spaniel Puppy" />
        </div>
        <div class="breeder-badge">
          <span class="badge-inner">CAVALIER<br/>BREEDER</span>
        </div>
        <div class="dot-pattern dot-pattern-bottom"></div>
      </div>
    </div>
  </div>

  <div class="services-strip">
    <div class="services-container">
      <div class="service-card service-health">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </div>
        <div class="service-text">
          <h3>Health Guaranteed</h3>
          <p>Every puppy comes with a comprehensive 2-year genetic health guarantee</p>
        </div>
      </div>
      <div class="service-card service-akc">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <div class="service-text">
          <h3>AKC Registered</h3>
          <p>All our Cavalier puppies are registered with the American Kennel Club</p>
        </div>
      </div>
      <div class="service-card service-family">
        <div class="service-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        </div>
        <div class="service-text">
          <h3>Family Raised</h3>
          <p>Puppies raised in our home with love, socialization, and daily enrichment</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    overflow: hidden;
    padding: 0;
    background: #F9F9F6;
  }

  .hero-main {
    position: relative;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: grid;
    grid-template-columns: 55% 45%;
    align-items: center;
    gap: 2rem;
  }

  .hero-content {
    padding-right: 2rem;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    color: #1A1A1A;
    margin: 0 0 1.5rem;
    letter-spacing: -1px;
  }

  .highlight-word {
    position: relative;
    display: inline-block;
  }

  .underline-svg {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 12px;
  }

  .hero-description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #666666;
    margin: 0 0 2rem;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 2rem;
  }

  .btn-get-started {
    display: inline-flex;
    align-items: center;
    background: #F5C518;
    color: #1A1A1A;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(245, 197, 24, 0.3);
  }

  .btn-get-started:hover {
    background: #D4A800;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 197, 24, 0.4);
    color: #1A1A1A;
  }

  .btn-how-it-works {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1A1A1A;
    color: #FFFFFF;
    padding: 0.9rem 2rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .btn-how-it-works svg {
    width: 18px;
    height: 18px;
  }

  .btn-how-it-works:hover {
    background: #333333;
    transform: translateY(-2px);
    color: #FFFFFF;
  }

  .slide-counter {
    font-size: 0.9rem;
    font-weight: 600;
    color: #999;
    letter-spacing: 2px;
  }

  /* Right side image */
  .hero-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image {
    position: relative;
    width: 100%;
    max-width: 450px;
    border-radius: 20px 20px 20px 80px;
    overflow: hidden;
    border: 4px solid #F5C518;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  }

  .hero-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* Dot patterns */
  .dot-pattern {
    position: absolute;
    width: 80px;
    height: 80px;
    background-image: radial-gradient(circle, #F5C518 2px, transparent 2px);
    background-size: 12px 12px;
    opacity: 0.5;
    z-index: 1;
  }

  .dot-pattern-top {
    top: -10px;
    right: -10px;
  }

  .dot-pattern-bottom {
    bottom: 20px;
    left: -20px;
  }

  /* Breeder badge */
  .breeder-badge {
    position: absolute;
    bottom: 30px;
    right: -15px;
    width: 80px;
    height: 80px;
    background: #F5C518;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(245, 197, 24, 0.4);
    z-index: 2;
  }

  .badge-inner {
    font-size: 0.6rem;
    font-weight: 800;
    color: #1A1A1A;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.3;
  }

  /* Services Strip */
  .services-strip {
    padding: 0 2rem 3rem;
  }

  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem 1.75rem;
    border-radius: 60px;
    transition: transform 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-3px);
  }

  .service-health {
    background: #F8C4A4;
  }

  .service-akc {
    background: #F5C518;
  }

  .service-family {
    background: #A8D8EA;
  }

  .service-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-icon svg {
    width: 28px;
    height: 28px;
    fill: #1A1A1A;
  }

  .service-text h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.25rem;
  }

  .service-text p {
    font-size: 0.85rem;
    color: rgba(26, 26, 26, 0.7);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .hero-container {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 2rem;
      gap: 2rem;
    }

    .hero-content {
      text-align: center;
      padding-right: 0;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-description {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .slide-counter {
      text-align: center;
    }

    .hero-image-wrapper {
      order: -1;
    }

    .hero-image {
      max-width: 350px;
      margin: 0 auto;
    }

    .hero-image img {
      height: 380px;
    }

    .breeder-badge {
      right: 5px;
      bottom: 20px;
      width: 70px;
      height: 70px;
    }

    .services-container {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-card {
      border-radius: 40px;
    }
  }

  @media (max-width: 480px) {
    .hero-container {
      padding: 2rem 1rem 1.5rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-description {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-image img {
      height: 300px;
    }

    .dot-pattern {
      display: none;
    }

    .services-strip {
      padding: 0 1rem 2rem;
    }
  }
</style>
